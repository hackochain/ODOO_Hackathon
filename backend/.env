# ==============================
# Flask Configuration
# ==============================

SECRET_KEY=transitops_secret_key_2026
JWT_SECRET_KEY=transitops_jwt_secret_key_2026


# ==============================
# MySQL Database
# ==============================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=transitops
DB_USER=root
DB_PASSWORD=password

DATABASE_URL=mysql+pymysql://root:password@localhost:3306/transitops


# ==============================
# Application Settings
# ==============================

FLASK_ENV=development
FLASK_DEBUG=True


# ==============================
# Upload Settings
# ==============================

UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE=16777216


# ==============================
# AI Settings
# ==============================

AI_MODEL=TransitOps_AI
AI_CONFIDENCE=0.90


# ==============================
# Tracking
# ==============================

GPS_REFRESH_INTERVAL=10


# ==============================
# Analytics
# ==============================

CACHE_TIMEOUT=300


# ==============================
# Reports
# ==============================

REPORT_FOLDER=reports